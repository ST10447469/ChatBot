<Window x:Class="ChatBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="800"
        Width="1200"
        Background="#101820"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Cybersecurity Awareness Bot"
                   Foreground="#00FF99"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Banner -->
        <TextBlock Grid.Row="1"
                   Foreground="Yellow"
                   FontFamily="Consolas"
                   FontSize="14"
                   TextAlignment="Center"
                   HorizontalAlignment="Center">
            <Run Text="========================================="/>
            <LineBreak/>
            <Run Text="     CYBERSECURITY AWARENESS BOT"/>
            <LineBreak/>
            <Run Text="========================================="/>
            <LineBreak/>
            <Run Text=" Stay Safe. Stay Smart. Stay Secure."/>
            <LineBreak/>
            <Run Text="========================================="/>
        </TextBlock>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Box -->
            <RichTextBox x:Name="ChatBox"
                         Grid.Column="0"
                         Background="#0B0F14"
                         Foreground="White"
                         FontSize="14"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,10,0"/>

            <!-- Side Panel -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="5,0,0,0">

                    <!-- Task Assistant -->
                    <Border Background="#1A2A3A" 
                            BorderBrush="#00FF99" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Task Assistant"
                                       Foreground="#00FF99"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <TextBox x:Name="TaskTitleBox"
                                     Height="30"
                                     Margin="0,5"
                                     VerticalContentAlignment="Center"
                                     Background="#2A3A4A"
                                     Foreground="White"
                                     BorderBrush="#00FF99"
                                     ToolTip="Enter task title"/>

                            <TextBox x:Name="TaskDescriptionBox"
                                     Height="60"
                                     Margin="0,5"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Background="#2A3A4A"
                                     Foreground="White"
                                     BorderBrush="#00FF99"
                                     ToolTip="Enter task description"/>

                            <DatePicker x:Name="ReminderDatePicker"
                                        Margin="0,5"
                                        Background="#2A3A4A"
                                        Foreground="White"
                                        BorderBrush="#00FF99"/>

                            <Button Content="Add Task"
                                    Height="35"
                                    Margin="0,5"
                                    Background="#00FF99"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    Click="AddTask_Click"/>

                            <Button Content="Mark Complete"
                                    Height="30"
                                    Margin="0,3"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="CompleteTask_Click"/>

                            <Button Content="Delete Task"
                                    Height="30"
                                    Margin="0,3"
                                    Background="#F44336"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="DeleteTask_Click"/>

                            <TextBlock Text="Your Tasks"
                                       Foreground="#00FF99"
                                       FontWeight="Bold"
                                       Margin="0,15,0,5"/>

                            <ListBox x:Name="TasksListBox"
                                     Height="120"
                                     Background="#0B0F14"
                                     Foreground="White"
                                     BorderBrush="#00FF99"/>
                        </StackPanel>
                    </Border>

                    <!-- Quiz Section -->
                    <Border Background="#1A2A3A" 
                            BorderBrush="#FFD700" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Cybersecurity Quiz"
                                       Foreground="#FFD700"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="QuizScoreDisplay" 
                                       Foreground="White" 
                                       FontSize="12"
                                       Text="Score: 0/0"/>

                            <Button Content="Start Quiz"
                                    Height="35"
                                    Margin="0,5"
                                    Background="#FFD700"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    Click="StartQuiz_Click"/>

                            <Button Content="Next Question"
                                    Height="30"
                                    Margin="0,3"
                                    Background="#FF9800"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="NextQuestion_Click"
                                    Visibility="Collapsed"
                                    x:Name="NextQuestionButton"/>

                            <TextBlock x:Name="QuizQuestionDisplay"
                                       Foreground="White"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,5"/>

                            <StackPanel x:Name="QuizOptionsPanel">
                                <!-- Options will be generated dynamically -->
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Activity Log -->
                    <Border Background="#1A2A3A" 
                            BorderBrush="#00BCD4" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Activity Log"
                                       Foreground="#00BCD4"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <Button Content="Show Recent Activity"
                                    Height="30"
                                    Margin="0,5"
                                    Background="#00BCD4"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    Click="ShowActivityLog_Click"/>

                            <ListBox x:Name="ActivityLogListBox"
                                     Height="100"
                                     Background="#0B0F14"
                                     Foreground="White"
                                     BorderBrush="#00BCD4"
                                     FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick Commands -->
                    <Border Background="#1A2A3A" 
                            BorderBrush="#9C27B0" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Quick Commands"
                                       Foreground="#9C27B0"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="'Show log' - View activity"
                                       Foreground="Gray" FontSize="10"/>
                            <TextBlock Text="'Start quiz' - Play quiz"
                                       Foreground="Gray" FontSize="10"/>
                            <TextBlock Text="'Add task: [title]' - Add task"
                                       Foreground="Gray" FontSize="10"/>
                            <TextBlock Text="'Help' - Show commands"
                                       Foreground="Gray" FontSize="10"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Input Area -->
        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBox x:Name="UserInputBox"
                     Height="40"
                     FontSize="16"
                     Margin="0,0,10,0"
                     VerticalContentAlignment="Center"
                     Background="#2A3A4A"
                     Foreground="White"
                     BorderBrush="#00FF99"
                     KeyDown="UserInputBox_KeyDown"/>
            <Button x:Name="SendButton"
                    Content="Send"
                    Width="120"
                    Height="40"
                    Background="#00FF99"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="SendButton_Click"/>
        </DockPanel>
    </Grid>
</Window>